# AI Game Platform 环境变量模板
# 复制本文件为 `.env`，再填写你实际要使用的配置。
#
# 启动方式：
#   python main.py
#   python main.py models
#
# 支持的游戏类型：
#   werewolf
#   avalon
#   codenames
#   texas_holdem
#   doudizhu
#   sanguosha


# -------------------------------------------------------------------
# 核心运行参数
# 这部分控制程序启动时默认运行哪个游戏、日志写到哪里、最多跑多少轮等。
# -------------------------------------------------------------------

# 选择要运行的游戏类型。
GAME_TYPE=werewolf

# 日志输出目录。每局游戏会在这里生成 game.jsonl / summary.json。
LOG_DIR=logs

# 最大回合数，防止游戏因为逻辑或模型行为卡成无限循环。
MAX_ROUNDS=50

# 是否在终端打印详细过程。true 表示打印每一步，false 表示更安静。
VERBOSE=true


# -------------------------------------------------------------------
# 模型通用默认参数
# 这部分是所有模型共享的默认推理参数；如果某个 provider 没有单独覆盖，
# 就会使用这里的值。
# -------------------------------------------------------------------

# 采样温度。越高越发散，越低越稳定。
MODEL_TEMPERATURE=0.8

# 单次回复允许的最大输出 token 数。
MODEL_MAX_TOKENS=1024

# 所有 provider 的默认超时时间（秒）。
# 如果下面某个 provider 设置了自己的 *_TIMEOUT_SECONDS，就以它为准。
MODEL_TIMEOUT_SECONDS=120


# -------------------------------------------------------------------
# 玩家分配配置
# 这部分决定“本局有哪些 AI 玩家参加，每个玩家用什么模型”。
# -------------------------------------------------------------------

# 写法格式：
#   provider:count
#   provider:model_name:count
#   @preset_name
#
# 示例：
#   PLAYER_CONFIG=deepseek:2
#   PLAYER_CONFIG=deepseek:deepseek-v4-pro:2,openai:gpt-5.4:2
#   PLAYER_CONFIG=@sgs_8p_freeforall
#
# 全局玩家配置，适用于大多数游戏。
# 如果留空，程序会自动扫描已填写 KEY 的 provider，并为每个 provider 创建 2 个玩家。
PLAYER_CONFIG=deepseek:2,dashscope:qwen3.7-max:2


# -------------------------------------------------------------------
# 游戏专用玩家配置
# 某些游戏会优先读取自己的独立配置，而不是上面的 PLAYER_CONFIG。
# -------------------------------------------------------------------

# 斗地主专用玩家配置。
# 仅当 `GAME_TYPE=doudizhu` 时使用，通常需要正好 3 名玩家。
DOUDIZHU_PLAYER_CONFIG=deepseek:deepseek-v4-pro:1,dashscope:kimi-k2-thinking:1,dashscope:glm-5.1:1

# 狼人杀专用玩家配置。
# 仅当 `GAME_TYPE=werewolf` 时使用。
# 玩家总数会决定使用几人局角色模板，例如 6 人、9 人、10 人局。
# 如果未填写，会优先回退到 `PLAYER_CONFIG`；如果 `PLAYER_CONFIG` 也未填写，则使用下面这个 6 人局示例。
WEREWOLF_PLAYER_CONFIG=deepseek:2,openai:2,qwen:2

# 三国杀模式。
# free_for_all = 混战模式
# identity = 身份模式
SGS_MODE=free_for_all

# 三国杀专用玩家配置。
# 仅当 `GAME_TYPE=sanguosha` 时使用。
SGS_PLAYER_CONFIG=deepseek:1,dashscope:qwen3.7-max:1,dashscope:kimi-k2.6:1,dashscope:glm-5.1:1


# -------------------------------------------------------------------
# Provider API Key
# 只需要填写你实际要接入的平台即可，没用到的可以留空。
# -------------------------------------------------------------------

# DeepSeek 的 API Key。
DEEPSEEK_KEY=

# OpenAI 的 API Key。
OPENAI_KEY=

# Google Gemini 的 API Key。
GEMINI_KEY=

# 阿里 Qwen 直连的 API Key。
QWEN_KEY=

# 智谱 GLM 的 API Key。
ZHIPU_KEY=

# Moonshot / Kimi 的 API Key。
MOONSHOT_KEY=

# Groq 的 API Key。
GROQ_KEY=

# SiliconFlow 的 API Key。
SILICONFLOW_KEY=

# 豆包 / 火山引擎 Ark 的 API Key。
DOUBAO_KEY=

# 阿里云 DashScope 的 API Key。
# 一个 Key 可以接多个模型，如 Qwen / Kimi / GLM / MiniMax。
DASHSCOPE_KEY=

# xAI Grok 的 API Key。
XAI_KEY=

# OpenRouter 的 API Key。
OPENROUTER_KEY=

# Together AI 的 API Key。
TOGETHER_KEY=


# -------------------------------------------------------------------
# 可选的 provider 模型覆盖项
# 如果留空，程序会从 config/models.yaml 里取默认模型。
# 只有当你想强制指定某个平台用哪个模型时才需要改。
# -------------------------------------------------------------------

# DeepSeek 要使用的模型名，例如 deepseek-v4-pro。
DEEPSEEK_MODEL=

# OpenAI 要使用的模型名，例如 gpt-5.4。
OPENAI_MODEL=

# Gemini 要使用的模型名，例如 gemini-2.5-pro。
GEMINI_MODEL=

# Qwen 要使用的模型名。
QWEN_MODEL=

# 智谱要使用的模型名。
ZHIPU_MODEL=

# Moonshot 要使用的模型名。
MOONSHOT_MODEL=

# Groq 要使用的模型名。
GROQ_MODEL=

# SiliconFlow 要使用的模型名。
SILICONFLOW_MODEL=

# 豆包要使用的模型名。
DOUBAO_MODEL=

# DashScope 要使用的模型名。
DASHSCOPE_MODEL=

# xAI 要使用的模型名。
XAI_MODEL=

# OpenRouter 要使用的模型名。
OPENROUTER_MODEL=

# Together AI 要使用的模型名。
TOGETHER_MODEL=


# -------------------------------------------------------------------
# 可选的 provider Base URL 覆盖项
# 一般只有在你使用代理、中转网关、私有部署或兼容接口时才需要填写。
# 留空时会使用 config/models.yaml 或代码里的默认地址。
# -------------------------------------------------------------------

# DeepSeek 接口地址。
DEEPSEEK_BASE_URL=

# OpenAI 接口地址。
OPENAI_BASE_URL=

# Qwen 接口地址。
QWEN_BASE_URL=

# 智谱接口地址。
ZHIPU_BASE_URL=

# Moonshot 接口地址。
MOONSHOT_BASE_URL=

# Groq 接口地址。
GROQ_BASE_URL=

# SiliconFlow 接口地址。
SILICONFLOW_BASE_URL=

# 豆包接口地址。
DOUBAO_BASE_URL=

# DashScope 接口地址。
DASHSCOPE_BASE_URL=

# xAI 接口地址。
XAI_BASE_URL=

# OpenRouter 接口地址。
OPENROUTER_BASE_URL=

# Together AI 接口地址。
TOGETHER_BASE_URL=


# -------------------------------------------------------------------
# 可选的 provider 超时覆盖项（单位：秒）
# 如果某个平台响应更慢，或者你希望它更早失败，可以在这里单独调整。
# 留空时会使用上面的 MODEL_TIMEOUT_SECONDS。
# -------------------------------------------------------------------

# DeepSeek 单独超时。
DEEPSEEK_TIMEOUT_SECONDS=

# OpenAI 单独超时。
OPENAI_TIMEOUT_SECONDS=

# Qwen 单独超时。
QWEN_TIMEOUT_SECONDS=

# 智谱单独超时。
ZHIPU_TIMEOUT_SECONDS=

# Moonshot 单独超时。
MOONSHOT_TIMEOUT_SECONDS=

# Groq 单独超时。
GROQ_TIMEOUT_SECONDS=

# SiliconFlow 单独超时。
SILICONFLOW_TIMEOUT_SECONDS=

# 豆包单独超时。
DOUBAO_TIMEOUT_SECONDS=

# DashScope 单独超时。
DASHSCOPE_TIMEOUT_SECONDS=

# xAI 单独超时。
XAI_TIMEOUT_SECONDS=

# OpenRouter 单独超时。
OPENROUTER_TIMEOUT_SECONDS=

# Together AI 单独超时。
TOGETHER_TIMEOUT_SECONDS=
